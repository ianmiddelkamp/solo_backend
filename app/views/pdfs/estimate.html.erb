<%= render 'pdfs/document_header',
      title: 'ESTIMATE',
      document: @estimate,
      client: @client,
      business: @business,
      to_label: 'Prepared For',
      logo_data_uri: @logo_data_uri,
      subtitle: "Project: #{@project.name}" %>

<table>
  <thead>
    <tr>
      <th>Task</th>
      <th class="right">Est. Hours</th>
      <th class="right">Rate</th>
      <th class="right">Amount</th>
    </tr>
  </thead>
  <tbody>
    <% @items.each do |item| %>
      <tr>
        <td><%= item.description.presence || "—" %></td>
        <td class="right"><%= "%.2f" % item.hours %></td>
        <td class="right">$<%= "%.2f" % item.rate %></td>
        <td class="right">$<%= "%.2f" % item.amount %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<% subtotal   = @items.sum(&:amount)
   tax_amount = @items.sum { |i| i.amount * i.tax_rate / 100 }
   tax_rate   = @items.map(&:tax_rate).find { |r| r > 0 } %>
<div class="total-section">
  <div style="min-width:320px;">
    <% if tax_amount > 0 %>
      <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
        <span class="total-label">Subtotal</span>
        <span style="font-size:12px; color:#374151;">$<%= "%.2f" % subtotal %></span>
      </div>
      <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
        <span class="total-label">HST (<%= "%.4g" % tax_rate %>%)<% if @business.hst_number.present? %> &middot; Reg# <%= @business.hst_number %><% end %></span>
        <span style="font-size:12px; color:#374151;">$<%= "%.2f" % tax_amount %></span>
      </div>
    <% end %>
    <div style="display:flex; justify-content:space-between; align-items:baseline; padding-top:6px; border-top:1px solid #e5e7eb;">
      <span class="total-label">Estimated Total</span>
      <span class="total-amount">$<%= "%.2f" % @estimate.total %></span>
    </div>
  </div>
</div>

<div class="footer">
  <%= @business.estimate_footer.presence || "This is an estimate only. The final invoice may vary based on actual hours worked." %><br/>
  Thank you for your business.
</div>
