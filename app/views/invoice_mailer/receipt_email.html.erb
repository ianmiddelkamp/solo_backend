<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <style>
      body        { font-family: Helvetica, Arial, sans-serif; color: #111827; font-size: 14px; margin: 0; padding: 0; background: #f3f4f6; }
      .wrapper    { max-width: 600px; margin: 32px auto; background: #ffffff; border-radius: 8px; overflow: hidden; }
      .body       { padding: 28px 32px; }
      .body p     { margin: 0 0 16px; line-height: 1.6; color: #374151; }
      .footer     { padding: 16px 32px; background: #f9fafb; border-top: 1px solid #e5e7eb; font-size: 12px; color: #6b7280; }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <table width="100%" cellpadding="0" cellspacing="0" style="background:#ffffff; border-bottom:2px solid <%= @business.primary_color.presence || '#4338ca' %>;">
        <tr>
          <td style="padding:28px 32px; vertical-align:middle;">
            <% if attachments["logo"] %>
              <img src="<%= attachments["logo"].url %>" alt="<%= @business.name %>" style="max-height:56px; max-width:160px; object-fit:contain; display:block;">
            <% else %>
              <span style="font-size:13px; font-weight:600; color:#111827;"><%= @business.name %></span>
            <% end %>
          </td>
          <td style="padding:28px 32px; text-align:right; vertical-align:middle;">
            <div style="color:#111827; font-size:22px; font-weight:700; margin:0;"><%= @invoice.number %></div>
            <div style="color:#6b7280; font-size:13px; margin-top:4px;"><%= @business.name.presence || "Invoice" %></div>
          </td>
        </tr>
      </table>

      <div class="body">
        <p>Hi <%= @client.contact_name.presence || @client.name %>,</p>
        <p>Thank you — we have received your payment of <strong>$<%= "%.2f" % @invoice.amount_paid %></strong> on <strong><%= @invoice.paid_at.in_time_zone.strftime("%B %-d, %Y") %></strong>.</p>
        <p>Your paid invoice is attached for your records.</p>
        <p><%= @business.invoice_footer.presence || "Thank you for your business." %></p>

        <% if @business.name.present? %>
          <p style="color: #6b7280; font-size: 13px;">
            <%= @business.name %><br/>
            <% if @business.email.present? %><%= @business.email %><br/><% end %>
            <% if @business.phone.present? %><%= @business.phone %><br/><% end %>
            <% if @business.hst_number.present? %>HST # <%= @business.hst_number %><% end %>
          </p>
        <% end %>
      </div>

      <div class="footer">
        Your paid invoice is attached for your records.
      </div>
    </div>
  </body>
</html>
