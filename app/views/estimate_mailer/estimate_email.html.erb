<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <style>
      body        { font-family: Helvetica, Arial, sans-serif; color: #111827; font-size: 14px; margin: 0; padding: 0; background: #f3f4f6; }
      .wrapper    { max-width: 600px; margin: 32px auto; background: #ffffff; border-radius: 8px; overflow: hidden; }
      .body       { padding: 28px 32px; }
      .body p     { margin: 0 0 16px; line-height: 1.6; color: #374151; }
      table       { width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 13px; }
      th          { background: <%= @business.primary_color.presence || '#4338ca' %>; color: #ffffff; text-align: left; padding: 8px 10px; }
      th.right,
      td.right    { text-align: right; }
      td          { padding: 8px 10px; border-bottom: 1px solid #e5e7eb; color: #374151; }
      tr:nth-child(even) td { background: #f9fafb; }
      .total-row td { font-weight: bold; border-top: 2px solid #e5e7eb; border-bottom: none; }
      .footer     { padding: 16px 32px; background: #f9fafb; border-top: 1px solid #e5e7eb; font-size: 12px; color: #6b7280; }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <table width="100%" cellpadding="0" cellspacing="0" style="background:#ffffff; border-bottom:2px solid <%= @business.primary_color.presence || '#4338ca' %>;">
        <tr>
          <td style="padding:28px 32px; vertical-align:middle;">
            <% if attachments["logo"] %>
              <img src="<%= attachments["logo"].url %>" alt="<%= @business.name %>" style="max-height:56px; max-width:160px; object-fit:contain; display:block;">
            <% else %>
              <span style="font-size:13px; font-weight:600; color:#111827;"><%= @business.name %></span>
            <% end %>
          </td>
          <td style="padding:28px 32px; text-align:right; vertical-align:middle;">
            <div style="color:#111827; font-size:22px; font-weight:700; margin:0;"><%= @estimate.number %></div>
            <div style="color:#6b7280; font-size:13px; margin-top:4px;"><%= @project.name %> &mdash; <%= @business.name.presence || "Estimate" %></div>
          </td>
        </tr>
      </table>

      <div class="body">
        <p>Hi <%= @client.contact_name.presence || @client.name %>,</p>
        <% if @changes %>
          <p>Please find an <strong>updated estimate</strong> attached. Here's a summary of what changed:</p>
          <table style="margin-bottom: 8px;">
            <thead><tr><th>Change</th><th>Detail</th></tr></thead>
            <tbody>
              <% @changes[:added].each do |i| %>
                <tr><td>Added</td><td><%= i["description"] %> (<%= "%.2f" % i["hours"] %>h)</td></tr>
              <% end %>
              <% @changes[:removed].each do |i| %>
                <tr><td>Removed</td><td><%= i["description"] %></td></tr>
              <% end %>
              <% @changes[:changed].each do |i| %>
                <tr><td>Revised</td><td><%= i["description"] %> (<%= "%.2f" % i["old_hours"] %>h &rarr; <%= "%.2f" % i["new_hours"] %>h)</td></tr>
              <% end %>
              <tr class="total-row">
                <td>Total</td>
                <td>$<%= "%.2f" % @changes[:previous_total] %> &rarr; $<%= "%.2f" % @changes[:current_total] %></td>
              </tr>
            </tbody>
          </table>
          <p>Full breakdown below:</p>
        <% else %>
          <p>Please find your estimate attached. Here's a summary:</p>
        <% end %>

        <table>
          <thead>
            <tr>
              <th>Task</th>
              <th class="right">Est. Hours</th>
              <th class="right">Rate</th>
              <th class="right">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% @items.each do |item| %>
              <tr>
                <td><%= item.description.presence || "—" %></td>
                <td class="right"><%= "%.2f" % item.hours %></td>
                <td class="right">$<%= "%.2f" % item.rate %></td>
                <td class="right">$<%= "%.2f" % item.amount %></td>
              </tr>
            <% end %>
            <% subtotal   = @items.sum(&:amount)
               tax_amount = @items.sum { |i| i.amount * i.tax_rate / 100 }
               tax_rate   = @items.map(&:tax_rate).find { |r| r > 0 } %>
            <% if tax_amount > 0 %>
              <tr>
                <td colspan="3" class="right" style="color:#6b7280;">Subtotal</td>
                <td class="right" style="color:#6b7280;">$<%= "%.2f" % subtotal %></td>
              </tr>
              <tr>
                <td colspan="3" class="right" style="color:#6b7280;">HST (<%= "%.4g" % tax_rate %>%)</td>
                <td class="right" style="color:#6b7280;">$<%= "%.2f" % tax_amount %></td>
              </tr>
            <% end %>
            <tr class="total-row">
              <td colspan="3" class="right">Estimated Total</td>
              <td class="right">$<%= "%.2f" % @estimate.total %></td>
            </tr>
          </tbody>
        </table>

        <p>This is an estimate only. The final invoice may vary based on actual hours worked.</p>

        <% if @business.name.present? %>
          <p style="color: #6b7280; font-size: 13px;">
            <%= @business.name %><br/>
            <% if @business.email.present? %><%= @business.email %><br/><% end %>
            <% if @business.phone.present? %><%= @business.phone %><br/><% end %>
            <% if @business.hst_number.present? %>HST # <%= @business.hst_number %><% end %>
          </p>
        <% end %>
      </div>

      <div class="footer">
        The PDF estimate is attached to this email.
      </div>
    </div>
  </body>
</html>
